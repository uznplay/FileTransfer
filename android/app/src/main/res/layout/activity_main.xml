<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f0f2f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/indicator_running"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/presence_offline"
                android:contentDescription="Trạng thái" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server đã dừng"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:textColor="@android:color/black" />

        </LinearLayout>

        <!-- Thông tin kết nối -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin kết nối"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1a73e8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ truy cập từ máy tính:"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_ip_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="#1a73e8"
                    android:background="#e8f0fe"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:letterSpacing="0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mở địa chỉ này trên trình duyệt máy tính để gửi file"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#999" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- File vừa nhận -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File đã nhận"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0f9d58" />

                <TextView
                    android:id="@+id/tv_last_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chưa có file nào"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#555" />

                <Button
                    android:id="@+id/btn_open_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Mở thư mục Download/FileTransfer"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Hướng dẫn -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hướng dẫn nhanh"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Bấm 'Khởi động server' bên dưới"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#555" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Mở trình duyệt trên máy tính"
                    android:textSize="13sp"
                    android:textColor="#555" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3. Nhập địa chỉ IP hiển thị ở trên"
                    android:textSize="13sp"
                    android:textColor="#555" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4. Chọn file và bấm gửi"
                    android:textSize="13sp"
                    android:textColor="#555" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5. File sẽ được lưu vào Downloads/FileTransfer/"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#555" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Nút điều khiển -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_change_port"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đổi port"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_toggle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Khởi động server"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@android:color/holo_blue_light" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kết nối qua Wi-Fi nội bộ (cùng mạng / Hotspot)"
            android:textSize="12sp"
            android:textColor="#999"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</ScrollView>
